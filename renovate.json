{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "mergeConfidence:all-badges"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "update image",
      "fileMatch": [
        "(^|/).*\\.tf$"
      ],
      "matchStrings": [
        "\\s*image\\s*=\\s*\"(?<depName>.*?):(?<currentValue>.*?)\"\\s*#\\s*renovate docker\\n"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "rebaseWhen": "behind-base-branch",
  "schedule": [
    "after 8am and before 4pm every weekday"
  ],
  "timezone": "Europe/Oslo",
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all-minor-patch-updates",
      "groupSlug": "all-non-major"
    },
    {
      "matchPackageNames": [
        "github-actions"
      ],
      "matchDatasources": [
        "github-tags"
      ],
      "matchFileNames": [
        "\\.github\\/workflows\\/.*"
      ],
      "commitMessagePrefix": "ci(no-release): ",
      "commitMessageAction": "bump",
      "commitMessageTopic": "{{depName}} from {{currentVersion}} to {{newVersion}}"
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "addLabels": [
        "patch"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "addLabels": [
        "minor"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ]
    }
  ]
}